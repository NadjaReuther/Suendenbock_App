@model Suendenbock_App.Models.ViewModels.ThreadDetailViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Title;
}

<div class="thread-detail-container">

    <a asp-action="Forum" class="td-back-link">
        <span class="material-symbols-outlined">arrow_back</span>
        Zurück zum Forum
    </a>
    <div class="td-main-post">
        <div class="td-post-accent"></div>

        <div class="td-post-inner">
            <div class="td-post-meta">
                <div class="td-meta-left">
                    <span class="td-category-badge">
                        <span class="material-symbols-outlined">@Model.CategoryIcon</span>
                        @Model.CategoryName
                    </span>
                    <span class="td-meta-time">
                        <span class="material-symbols-outlined">schedule</span>
                        @Model.CreatedAt
                    </span>
                    <span class="td-meta-author">
                        <span class="material-symbols-outlined">person</span>
                        @Model.AuthorName
                    </span>
                    @if (Model.IsPinned)
                    {
                        <span class="td-pin-badge">
                            <span class="material-symbols-outlined">push_pin</span>
                            Angepinnt
                        </span>
                    }
                </div>

                @if (Model.CanDelete)
                {
                    <form asp-action="DeleteThread" asp-route-id="@Model.Id" method="post" class="td-delete-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="td-btn-delete"
                                onclick="return confirm('Thread wirklich archivieren?')"
                                title="Thread löschen">
                            <span class="material-symbols-outlined">delete</span>
                            Löschen
                        </button>
                    </form>
                }
            </div>

            <h1 class="td-title">@Model.Title</h1>
            <div class="td-content-box">
                <div class="td-content wiki-content">
                    @Html.Raw(Model.Content)
                </div>
            </div>
        </div>
    </div>

    <div class="td-replies-section">
        <div class="td-replies-header">
            <h3 class="td-replies-title">Antworten (@Model.Replies.Count)</h3>
            <span class="material-symbols-outlined td-replies-icon">chat_bubble_outline</span>
        </div>

        @if (!Model.Replies.Any())
        {
            <div class="td-empty-replies">
                <span class="material-symbols-outlined">history_edu</span>
                <p>Stille herrscht in diesem Saal. Erhebt Eure Stimme!</p>
            </div>
        }
        else
        {
            @foreach (var reply in Model.Replies)
            {
                <div class="td-reply-card">
                    <div class="td-reply-header">
                        <div class="td-reply-author">
                            <div class="td-avatar">
                                <span class="material-symbols-outlined">person</span>
                            </div>
                            <span class="td-reply-name">@reply.AuthorName</span>
                        </div>
                        <div class="td-reply-actions">
                            <span class="td-reply-time">@reply.CreatedAt</span>
                            @if (reply.CanDelete)
                            {
                                <form asp-action="DeleteReply"
                                      asp-route-id="@reply.Id"
                                      asp-route-threadId="@Model.Id"
                                      method="post" class="td-inline-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="td-btn-icon-delete"
                                            onclick="return confirm('Antwort löschen?')"
                                            title="Antwort löschen">
                                        <span class="material-symbols-outlined">delete</span>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                    <div class="td-reply-content">
                        @reply.Content
                    </div>
                </div>
            }
        }
    </div>

    <div class="td-reply-form-card">
        <h4 class="td-reply-form-title">
            <span class="material-symbols-outlined">edit_note</span>
            Eure Replik verfassen
        </h4>
        <form asp-action="PostReply" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="threadId" value="@Model.Id" />
            <textarea name="content" rows="4" required
                      class="td-reply-textarea"
                      placeholder="Was habt Ihr zu dieser Kunde zu sagen?"></textarea>
            <div class="td-reply-form-footer">
                <button type="submit" class="td-btn-send">
                    <span class="material-symbols-outlined">send</span>
                    Absenden
                </button>
            </div>
        </form>
    </div>

</div>

@section Styles {
    <link rel="stylesheet" href="~/css/thread-detail.css" />
}