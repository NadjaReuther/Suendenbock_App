@model Suendenbock_App.Models.ViewModels.ForumPageViewModel
@{
    ViewData["Title"] = "Halle der Absprachen";
}

<div class="fp-container">
    <div class="fp-header">
        <div>
            <a asp-action="Index" class="fp-back-link">
                <span class="material-symbols-outlined">arrow_back</span>
                Zurück zur Halle
            </a>
            <h1 class="fp-title">Halle der Absprachen</h1>
        </div>
        <a asp-action="CreateThread" class="fp-btn-new">
            <span class="material-symbols-outlined">add_comment</span>
            Thema eröffnen
        </a>
    </div>
    <div class="fp-grid">
        <aside class="fp-sidebar">
            <div class="fp-sidebar-card">
                <p class="fp-sidebar-label">Suche</p>
                <form method="get" asp-action="Forum" class="fp-search-form">
                    <div class="fp-search-wrapper">
                        <span class="material-symbols-outlined fp-search-icon">search</span>
                        <input name="suche" value="@Model.Suche"
                               class="fp-search-input" placeholder="Schlagwort..." />
                    </div>
                    <input type="hidden" name="kategorie" value="@Model.AktiveKategorie" />
                </form>
                <p class="fp-sidebar-label">Kategorien</p>
                <nav class="fp-category-nav">
                    <a asp-action="Forum" asp-route-suche="@Model.Suche"
                       class="fp-cat-item @(Model.AktiveKategorie == null ? "active" : "")">
                        <span class="material-symbols-outlined">apps</span>
                        Alle
                    </a>
                    @foreach (var cat in Model.Categories)
                    {
                        <a asp-action="Forum"
                           asp-route-suche="@Model.Suche"
                           asp-route-kategorie="@cat.Name"
                           class="fp-cat-item @(Model.AktiveKategorie == cat.Name ? "active" : "")">
                            <span class="material-symbols-outlined">@cat.Icon</span>
                            @cat.Name
                        </a>
                    }
                </nav>
            </div>
        </aside>
        <main class="fp-threads">
            @if (!Model.Threads.Any())
            {
                <div class="fp-empty">
                    <span class="material-symbols-outlined">history_edu</span>
                    <p>Keine Themen gefunden.</p>
                </div>
            }
            @foreach (var thread in Model.Threads)
            {
                <a asp-action="ThreadDetail" asp-route-id="@thread.Id"
                   class="fp-thread-card @(thread.IsPinned ? "pinned" : "")">
                    <div class="fp-thread-icon">
                        <span class="material-symbols-outlined">@thread.CategoryIcon</span>
                    </div>
                    <div class="fp-thread-body">
                        <div class="fp-thread-meta">
                            <span class="fp-thread-badge">@thread.CategoryName</span>
                            <span class="fp-thread-time">@thread.CreatedAt</span>
                            @if (thread.IsPinned)
                            {
                                <span class="fp-pin-badge">
                                    <span class="material-symbols-outlined">push_pin</span>
                                    Angepinnt
                                </span>
                            }
                        </div>
                        <h2 class="fp-thread-title">@thread.Title</h2>
                        <div class="fp-thread-footer">
                            <span>@thread.AuthorName</span>
                            <span>•</span>
                            <span>@thread.ReplyCount Antworten</span>
                        </div>
                    </div>
                    @if (thread.CanDelete)
                    {
                        <form asp-action="DeleteThread" asp-route-id="@thread.Id"
                              method="post" class="fp-delete-form"
                              onclick="event.stopPropagation()">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="fp-btn-delete"
                                    data-delete-form="true" data-delete-message="Thread wirklich archivieren?"
                                    title="Thema löschen">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </form>
                    }
                </a>
            }
        </main>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/forum-page.css" />
}