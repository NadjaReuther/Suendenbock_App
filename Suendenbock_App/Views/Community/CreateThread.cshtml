@model Suendenbock_App.Models.ViewModels.CreateThreadViewModel
@{
    ViewData["Title"] = "Neues Thema";
}

<div class="create-thread-container">
    <a asp-action="Forum" class="back-link">
        <span class="material-symbols-outlined">arrow_back</span>
        <span>Zurück zum Forum</span>
    </a>

    <h1 class="page-title">Neues Thema eröffnen</h1>

    <div class="create-thread-card">
        <form asp-action="CreateThread" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="CategoryId" class="form-label">Kategorie</label>
                <select asp-for="CategoryId" class="form-select"
                        asp-items="@(new SelectList(Model.Categories, "Id", "Name"))">
                    <option value="">Kategorie wählen...</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Title" class="form-label">Titel</label>
                <input asp-for="Title" class="form-control" placeholder="Titel des Themas..." />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Content" class="form-label">Nachricht</label>
                <textarea asp-for="Content" id="forumEditor" rows="10"
                          class="form-control"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <a asp-action="Forum" class="btn-secondary">Abbrechen</a>
                <button type="submit" class="btn-primary">
                    <span class="material-symbols-outlined">send</span>
                    Verkünden
                </button>
            </div>
        </form>
    </div>
</div>
@section Styles {
    <link rel="stylesheet" href="~/css/forum.css" />
}
@section Scripts {
    <script>
        // CKEditor – gleiche Aktivierung wie bei allen anderen Beschreibungsfeldern
        ClassicEditor.create(document.querySelector('#forumEditor')).catch(console.error);
    </script>
}