@model List<Suendenbock_App.Models.Domain.GlossaryEntry>

@{
    ViewData["Title"] = "Glossar";

    // Helper-Funktion für Display-Namen
    string GetDisplayName(string entityType)
    {
        var entityTypes = (Dictionary<string, string>)ViewBag.EntityTypes;
        return entityTypes.TryGetValue(entityType ?? "", out var displayName) ? displayName : entityType;
    }
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-4">📚 Glossar-Verwaltung</h1>
            <p class="text-muted">Verwalte Beschreibungen für alle Begriffe deines Universums</p>
        </div>
    </div>

    <!-- Suche und Filter -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <form asp-action="Index" method="get">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label for="searchTerm" class="form-label">Suchbegriff</label>
                                <input type="text"
                                       class="form-control"
                                       id="searchTerm"
                                       name="searchTerm"
                                       value="@ViewBag.SearchTerm"
                                       placeholder="Titel oder Beschreibung durchsuchen...">
                            </div>
                            <div class="col-md-3">
                                <label for="entityType" class="form-label">Typ filtern</label>
                                <select class="form-select" id="entityType" name="entityType">
                                    <option value="">Alle Typen</option>
                                    <option disabled>---</option>
                                    <option value="" selected="@(string.IsNullOrEmpty(ViewBag.EntityType) ? "selected" : null)">Freie Einträge</option>
                                    @foreach (var typeEntry in (Dictionary<string, string>)ViewBag.EntityTypes)
                                    {
                                        <option value="@typeEntry.Key" selected="@(ViewBag.EntityType == typeEntry.Key ? "selected" : null)">@typeEntry.Value</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="category" class="form-label">Kategorie filtern</label>
                                <select class="form-select" id="category" name="category">
                                    <option value="">Alle Kategorien</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        @foreach (var cat in ViewBag.Categories)
                                        {
                                            <option value="@cat" selected="@(ViewBag.Category == cat ? "selected" : null)">@cat</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-search"></i> Suchen
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Aktionen -->
    <div class="row mb-3">
        <div class="col-12">
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Neuer Eintrag
            </a>
        </div>
    </div>

    <!-- Ergebnisse -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Glossar-Einträge (@Model.Count)</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Titel</th>
                                        <th>Typ / Kategorie</th>
                                        <th>Beschreibung</th>
                                        <th style="width: 200px;">Aktionen</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@entry.Title</strong>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(entry.EntityType))
                                                {
                                                    <span class="badge bg-info">@GetDisplayName(entry.EntityType)</span>
                                                }
                                                else if (!string.IsNullOrEmpty(entry.Category))
                                                {
                                                    <span class="badge bg-success">@entry.Category</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Frei</span>
                                                }
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    @{
                                                        // HTML-Tags entfernen für die Anzeige
                                                        var plainText = System.Text.RegularExpressions.Regex.Replace(entry.Description, "<.*?>", string.Empty);
                                                        var displayText = plainText.Length > 100
                                                            ? plainText.Substring(0, 100) + "..."
                                                            : plainText;
                                                    }
                                                    @displayText
                                                </small>
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Show" asp-route-id="@entry.Id" class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-eye"></i> Anzeigen
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@entry.Id" class="btn btn-sm btn-outline-warning">
                                                        <i class="bi bi-pencil"></i> Bearbeiten
                                                    </a>
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-danger"
                                                            onclick="deleteEntry(@entry.Id, '@entry.Title')">
                                                        <i class="bi bi-trash"></i> Löschen
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-5 text-muted">
                            <i class="bi bi-search" style="font-size: 3rem;"></i>
                            <p class="mt-3">Keine Einträge gefunden</p>
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="bi bi-plus-circle"></i> Ersten Eintrag erstellen
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Form (hidden) -->
<form id="deleteForm" method="post" style="display: none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        function deleteEntry(id, title) {
            Swal.fire({
                title: 'Seid Ihr sicher?',
                text: `Der Eintrag "${title}" wird unwiderruflich gelöscht.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#B89E68',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Ja, löschen',
                cancelButtonText: 'Abbrechen',
                background: '#FFFCF7',
                color: '#2D241E'
            }).then((result) => {
                if (result.isConfirmed) {
                    var form = document.getElementById('deleteForm');
                    form.action = '@Url.Action("Delete", "Glossary")/' + id;
                    form.submit();
                }
            });
        }
    </script>
}