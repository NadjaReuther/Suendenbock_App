@model Suendenbock_App.Models.Domain.GlossaryEntry

@{
    ViewData["Title"] = "Neuer Glossar-Eintrag";
}

@section Styles {
    <link href="/css/forms.css" rel="stylesheet" />
    <link href="/css/wysiwyg-editor.css" rel="stylesheet" />
}

<div class="steckbrief-background">
    <div class="steckbrief-container">
        <div class="steckbrief-title">@ViewData["Title"]</div>

        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">Glossar</a></li>
                <li class="breadcrumb-item active">Neuer Eintrag</li>
            </ol>
        </nav>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row mt-4">
                <!-- Eintragstyp Auswahl -->
                <div class="col-12">
                    <div class="card mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">📝 Eintragstyp</h5>
                        </div>
                        <div class="card-body">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="radio" name="entryType" id="freeEntry" value="free" checked onchange="toggleEntitySelection()">
                                <label class="form-check-label" for="freeEntry">
                                    <strong>Freier Eintrag</strong> - Ein Begriff ohne Verknüpfung zu einer bestehenden Entität
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="entryType" id="linkedEntry" value="linked" onchange="toggleEntitySelection()">
                                <label class="form-check-label" for="linkedEntry">
                                    <strong>Verknüpfter Eintrag</strong> - Beschreibung für eine bestehende Entität (Rasse, Magieklasse, etc.)
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Titel (für freie Einträge) -->
                <div class="col-md-6" id="titleSection">
                    <div class="form-group mb-3">
                        <label for="title" class="form-label">Titel <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="title" name="Title" asp-for="Title" required>
                        <small class="form-text text-muted">Der Name des Begriffs</small>
                    </div>
                </div>

                <!-- Kategorie (für freie Einträge) -->
                <div class="col-md-6" id="categorySection">
                    <div class="form-group mb-3">
                        <label for="category" class="form-label">Kategorie (optional)</label>
                        <select class="form-select category-select" id="category" name="Category" asp-for="Category">
                            <option value="">-- Keine Kategorie --</option>
                        </select>
                        <small class="form-text text-muted">Wähle eine Kategorie oder erstelle eine neue durch Eingabe</small>
                    </div>
                </div>

                <!-- Entitäts-Auswahl (für verknüpfte Einträge) -->
                <div class="col-12" id="entitySection" style="display: none;">
                    <div class="card mb-4">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">🔗 Entitäts-Verknüpfung</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label for="entityType" class="form-label">Entitäts-Typ</label>
                                    <select class="form-select" id="entityType" name="EntityType" onchange="initEntitySelect()">
                                        <option value="">-- Typ wählen --</option>
                                        @foreach (var type in ViewBag.EntityTypes)
                                        {
                                            <option value="@type">@type</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-8 mb-3">
                                    <label for="entityId" class="form-label">Entität auswählen</label>
                                    <select class="form-select entity-select" id="entityId" name="EntityId" asp-for="EntityId" disabled>
                                        <option value="">Erst Entitäts-Typ wählen...</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bild-Upload -->
                <div class="col-12">
                    <div class="card mb-4">
                        <div class="card-header bg-secondary text-white">
                            <h5 class="mb-0">🖼️ Bild</h5>
                        </div>
                        <div class="card-body">
                            <div class="form-group">
                                <label for="entryImage" class="form-label">Bild hochladen (optional)</label>
                                <input type="file" class="form-control" id="entryImage" name="entryImage" accept="image/*">
                                <small class="form-text text-muted">Erlaubte Formate: JPG, PNG, GIF</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Beschreibung mit WYSIWYG-Editor -->
                <div class="col-12">
                    <div class="card mb-4">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">📖 Beschreibung</h5>
                        </div>
                        <div class="card-body">
                            <div class="form-group">
                                <label for="description" class="form-label">Beschreibung <span class="text-danger">*</span></label>
                                <textarea class="form-control d-none" id="description" name="Description" asp-for="Description" required></textarea>
                                <div id="wysiwyg-editor"></div>
                                <small class="form-text text-muted">
                                    💡 Tipp: Verwende @@ um auf andere Entitäten zu verlinken (z.B. @@character:5 oder @@guild:3)
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Aktionen -->
                <div class="col-12 text-center">
                    <a asp-action="Index" class="btn btn-secondary me-3">
                        <i class="bi bi-arrow-left"></i> Abbrechen
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Eintrag erstellen
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script src="~/js/entity-mentions.js"></script>
    <script>
        let editor;

        // WYSIWYG Editor initialisieren
        ClassicEditor
            .create(document.querySelector('#wysiwyg-editor'), {
                toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', '|', 'blockQuote', 'undo', 'redo']
            })
            .then(newEditor => {
                editor = newEditor;
                window.currentEditor = newEditor; // Für Entity-Mentions

                // Initiale Daten setzen
                const descriptionTextarea = document.getElementById('description');
                if (descriptionTextarea.value) {
                    editor.setData(descriptionTextarea.value);
                }

                // Bei Änderungen im Editor das Textarea aktualisieren
                editor.model.document.on('change:data', () => {
                    descriptionTextarea.value = editor.getData();
                });

                // Entity-Mentions initialisieren
                setTimeout(() => {
                    new EntityMentions('#description');
                }, 800);
            })
            .catch(error => {
                console.error(error);
            });

        // Toggle zwischen freiem und verknüpftem Eintrag
        function toggleEntitySelection() {
            const isFree = document.getElementById('freeEntry').checked;
            document.getElementById('titleSection').style.display = isFree ? 'block' : 'none';
            document.getElementById('categorySection').style.display = isFree ? 'block' : 'none';
            document.getElementById('entitySection').style.display = isFree ? 'none' : 'block';

            if (isFree) {
                document.getElementById('entityType').value = '';
                $('#entityId').val(null).trigger('change');
                document.getElementById('title').required = true;
            } else {
                document.getElementById('title').required = false;
            }
        }

        // Initialisiere Select2 für Entitäts-Auswahl basierend auf dem gewählten Typ
        function initEntitySelect() {
            const entityType = document.getElementById('entityType').value;
            const entitySelect = $('#entityId');

            // Zerstöre vorherige Select2-Instanz falls vorhanden
            if (entitySelect.hasClass('select2-hidden-accessible')) {
                entitySelect.select2('destroy');
            }

            // Reset
            entitySelect.empty().append('<option value="">-- Bitte wählen --</option>');

            if (!entityType) {
                entitySelect.prop('disabled', true);
                return;
            }

            // Spezialbehandlung für MagicClass (kann nicht direkt erstellt werden)
            const canCreateNew = entityType !== 'MagicClass';

            // Initialisiere Select2 mit AJAX und Tags
            entitySelect.select2({
                ajax: {
                    url: '@Url.Action("SearchEntities")',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return {
                            entityType: entityType,
                            searchTerm: params.term || ''
                        };
                    },
                    processResults: function (data) {
                        return {
                            results: data.map(item => ({
                                id: item.id,
                                text: item.name
                            }))
                        };
                    },
                    cache: true
                },
                tags: canCreateNew,
                createTag: canCreateNew ? function (params) {
                    var term = $.trim(params.term);
                    if (term === '') {
                        return null;
                    }
                    return {
                        id: 'new:' + term,
                        text: term + ' (neu erstellen)',
                        newTag: true
                    };
                } : undefined,
                minimumInputLength: 0,
                placeholder: canCreateNew ? 'Entität suchen oder neu erstellen...' : 'Entität suchen...',
                allowClear: true
            }).prop('disabled', false);

            // Event-Handler für Auswahl
            entitySelect.on('select2:select', function (e) {
                const selectedData = e.params.data;
                const selectedText = selectedData.text.replace(' (neu erstellen)', '');

                // Wenn es ein neuer Eintrag ist (ID beginnt mit "new:")
                if (selectedData.newTag && selectedData.id.startsWith('new:')) {
                    const newEntityName = selectedData.id.substring(4); // "new:" entfernen

                    // Zeige Ladeanzeige
                    entitySelect.prop('disabled', true);

                    // AJAX-Call zum Erstellen der neuen Entität
                    $.ajax({
                        url: '@Url.Action("CreateEntity")',
                        method: 'POST',
                        data: {
                            entityType: entityType,
                            name: newEntityName,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (response.success) {
                                // Ersetze die temporäre Option mit der echten ID
                                const newOption = new Option(response.name, response.id, true, true);
                                entitySelect.empty().append(newOption).trigger('change');
                                entitySelect.prop('disabled', false);

                                // Setze den Titel
                                document.getElementById('title').value = response.name;

                                // Erfolgs-Nachricht
                                alert(`✅ "${response.name}" wurde erfolgreich erstellt!`);
                            } else {
                                alert('❌ Fehler beim Erstellen: ' + response.message);
                                entitySelect.val(null).trigger('change').prop('disabled', false);
                            }
                        },
                        error: function () {
                            alert('❌ Fehler bei der Kommunikation mit dem Server');
                            entitySelect.val(null).trigger('change').prop('disabled', false);
                        }
                    });
                } else {
                    // Bestehende Entität ausgewählt
                    document.getElementById('title').value = selectedText;
                }
            });
        }

        // Initialisiere Kategorie-Select mit Tags (zum Erstellen neuer Kategorien)
        function initCategorySelect() {
            $('.category-select').select2({
                ajax: {
                    url: '@Url.Action("GetCategories")',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return {
                            searchTerm: params.term || ''
                        };
                    },
                    processResults: function (data) {
                        return {
                            results: data.map(item => ({
                                id: item,
                                text: item
                            }))
                        };
                    },
                    cache: true
                },
                tags: true,
                createTag: function (params) {
                    var term = $.trim(params.term);
                    if (term === '') {
                        return null;
                    }
                    return {
                        id: term,
                        text: term,
                        newTag: true
                    };
                },
                minimumInputLength: 0,
                placeholder: 'Kategorie wählen oder neu erstellen...',
                allowClear: true
            });
        }

        // Beim Laden der Seite
        document.addEventListener('DOMContentLoaded', function() {
            toggleEntitySelection();
            initCategorySelect();

            @if (!string.IsNullOrEmpty(ViewBag.SelectedEntityType))
            {
                <text>
                document.getElementById('linkedEntry').checked = true;
                document.getElementById('entityType').value = '@ViewBag.SelectedEntityType';
                toggleEntitySelection();
                initEntitySelect();

                @if (ViewBag.SelectedEntityId != null)
                {
                    <text>
                    // Vorauswahl setzen
                    setTimeout(function() {
                        const entityId = '@ViewBag.SelectedEntityId';
                        $('#entityId').val(entityId).trigger('change');
                    }, 500);
                    </text>
                }
                </text>
            }
        });
    </script>
}
